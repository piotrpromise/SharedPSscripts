{
  "$schema": "https://schema.management.azure.com/schemas/2019-04-01/deploymentTemplate.json#",
  "contentVersion": "1.0.0.0",
  "metadata": {
    "_comment": "Hand-authored ARM equivalent of main.bicep. Ships so the deployer works WITHOUT the Bicep CLI installed. Keep in sync with main.bicep."
  },
  "parameters": {
    "namePrefix": {
      "type": "string",
      "minLength": 1,
      "maxLength": 11,
      "metadata": { "description": "Short prefix (letters/numbers) put at the start of every resource name. Required - type your own, e.g. your company/product short name." }
    },
    "location": {
      "type": "string",
      "defaultValue": "polandcentral",
      "metadata": { "description": "Azure region the resources are created in (e.g. polandcentral, westeurope, uksouth)." }
    }
  },
  "variables": {
    "suffix": "[uniqueString(resourceGroup().id)]",
    "storageName": "[toLower(format('{0}{1}', parameters('namePrefix'), substring(variables('suffix'), 0, 6)))]",
    "funcName": "[format('{0}-func-{1}', parameters('namePrefix'), substring(variables('suffix'), 0, 5))]",
    "planName": "[format('{0}-plan', parameters('namePrefix'))]",
    "aiName": "[format('{0}-ai', parameters('namePrefix'))]",
    "lawName": "[format('{0}-law', parameters('namePrefix'))]",
    "storageBlobDataOwner": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', 'b7e6dc6d-f1e8-4753-8033-0f276bb0955b')]",
    "storageTableDataContributor": "[subscriptionResourceId('Microsoft.Authorization/roleDefinitions', '0a9a7e1f-b9d0-4cc4-a60d-0319b160aaa3')]"
  },
  "resources": [
    {
      "type": "Microsoft.Storage/storageAccounts",
      "apiVersion": "2023-05-01",
      "name": "[variables('storageName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Standard_LRS" },
      "kind": "StorageV2",
      "properties": {
        "minimumTlsVersion": "TLS1_2",
        "allowBlobPublicAccess": false
      }
    },
    {
      "type": "Microsoft.OperationalInsights/workspaces",
      "apiVersion": "2023-09-01",
      "name": "[variables('lawName')]",
      "location": "[parameters('location')]",
      "properties": {
        "sku": { "name": "PerGB2018" },
        "retentionInDays": 30
      }
    },
    {
      "type": "Microsoft.Insights/components",
      "apiVersion": "2020-02-02",
      "name": "[variables('aiName')]",
      "location": "[parameters('location')]",
      "kind": "web",
      "properties": {
        "Application_Type": "web",
        "WorkspaceResourceId": "[resourceId('Microsoft.OperationalInsights/workspaces', variables('lawName'))]"
      },
      "dependsOn": [
        "[resourceId('Microsoft.OperationalInsights/workspaces', variables('lawName'))]"
      ]
    },
    {
      "type": "Microsoft.Web/serverfarms",
      "apiVersion": "2023-12-01",
      "name": "[variables('planName')]",
      "location": "[parameters('location')]",
      "sku": { "name": "Y1", "tier": "Dynamic" },
      "properties": {}
    },
    {
      "type": "Microsoft.Web/sites",
      "apiVersion": "2023-12-01",
      "name": "[variables('funcName')]",
      "location": "[parameters('location')]",
      "kind": "functionapp",
      "identity": { "type": "SystemAssigned" },
      "properties": {
        "serverFarmId": "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "httpsOnly": true,
        "siteConfig": {
          "ftpsState": "Disabled",
          "minTlsVersion": "1.2",
          "appSettings": [
            { "name": "AzureWebJobsStorage__accountName", "value": "[variables('storageName')]" },
            { "name": "FUNCTIONS_EXTENSION_VERSION", "value": "~4" },
            { "name": "FUNCTIONS_WORKER_RUNTIME", "value": "dotnet-isolated" },
            { "name": "APPLICATIONINSIGHTS_CONNECTION_STRING", "value": "[reference(resourceId('Microsoft.Insights/components', variables('aiName')), '2020-02-02').ConnectionString]" },
            { "name": "TABLES_ACCOUNT_URI", "value": "[format('https://{0}.table.{1}', variables('storageName'), environment().suffixes.storage)]" }
          ]
        }
      },
      "dependsOn": [
        "[resourceId('Microsoft.Web/serverfarms', variables('planName'))]",
        "[resourceId('Microsoft.Insights/components', variables('aiName'))]",
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.Storage/storageAccounts/{0}', variables('storageName'))]",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('storageName')), resourceId('Microsoft.Web/sites', variables('funcName')), variables('storageBlobDataOwner'))]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('funcName')), '2023-12-01', 'full').identity.principalId]",
        "roleDefinitionId": "[variables('storageBlobDataOwner')]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]",
        "[resourceId('Microsoft.Web/sites', variables('funcName'))]"
      ]
    },
    {
      "type": "Microsoft.Authorization/roleAssignments",
      "apiVersion": "2022-04-01",
      "scope": "[format('Microsoft.Storage/storageAccounts/{0}', variables('storageName'))]",
      "name": "[guid(resourceId('Microsoft.Storage/storageAccounts', variables('storageName')), resourceId('Microsoft.Web/sites', variables('funcName')), variables('storageTableDataContributor'))]",
      "properties": {
        "principalId": "[reference(resourceId('Microsoft.Web/sites', variables('funcName')), '2023-12-01', 'full').identity.principalId]",
        "roleDefinitionId": "[variables('storageTableDataContributor')]",
        "principalType": "ServicePrincipal"
      },
      "dependsOn": [
        "[resourceId('Microsoft.Storage/storageAccounts', variables('storageName'))]",
        "[resourceId('Microsoft.Web/sites', variables('funcName'))]"
      ]
    }
  ],
  "outputs": {
    "functionAppName": {
      "type": "string",
      "value": "[variables('funcName')]"
    },
    "activationUrl": {
      "type": "string",
      "value": "[format('https://{0}/api/activate', reference(resourceId('Microsoft.Web/sites', variables('funcName')), '2023-12-01').defaultHostName)]"
    },
    "adminBaseUrl": {
      "type": "string",
      "value": "[format('https://{0}/api/admin', reference(resourceId('Microsoft.Web/sites', variables('funcName')), '2023-12-01').defaultHostName)]"
    }
  }
}
